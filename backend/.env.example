DATABASE_URL="postgresql://user:password@localhost:5432/manas_db"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:8081
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
EMAIL_OTP_DRY_RUN=false
ADMIN_EMAIL=admin@manas.app
ADMIN_PASSWORD=adminpass123
ADMIN_NAME=MANAS Admin
# In production, configure either JaaS or a self-hosted Jitsi server with JWT auth.
# Do not use public anonymous meet.jit.si rooms for production MANAS calls.
MEETING_PROVIDER=open_jitsi
MEETING_SERVER_URL=https://meet.jit.si
MEETING_APP_ID=
MEETING_JWT_KID=
MEETING_JWT_PRIVATE_KEY=
MEETING_JWT_SECRET=
MEETING_JWT_ALG=RS256
MEETING_TOKEN_TTL_MINUTES=120
MEETING_ENABLE_AUTH=false
CLOUDINARY_URL=
# Alternatively set all three instead of CLOUDINARY_URL:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

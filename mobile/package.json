  "scripts": {
    "start": "expo start",
    "postinstall": "node scripts/patch-android-gradle-node.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "deps:check": "expo install --check",
    "doctor": "expo-doctor",
    "export:android": "expo export --platform android --output-dir ./dist/android --clear",

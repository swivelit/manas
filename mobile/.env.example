# MANAS mobile public configuration.
# Copy to `.env.local` for local development. Do not commit real secrets.

# Backend API used by the MANAS mobile app.
EXPO_PUBLIC_API_URL=https://your-manas-api.example.com

# Debug-only local smoke. Never enable this for release builds.
EXPO_PUBLIC_E2E_MOCK_AUTH=0

# Firebase public web/mobile app config required before release verification can pass.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional Google OAuth client IDs. Required for production Google login.
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
